        <mxCell id="-ppM35XShmB3G3ZkOoFj-4" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;align=right;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;The Code Digger&lt;/h1&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;8,0,0&quot;&gt;&lt;b data-path-to-node=&quot;8,0,0&quot; data-index-in-node=&quot;0&quot;&gt;O que ele faz:&lt;/b&gt;&amp;nbsp;Ingestão de esquemas de banco de dados, AST de monolitos antigos e&amp;nbsp;&lt;i data-path-to-node=&quot;8,0,0&quot; data-index-in-node=&quot;82&quot;&gt;logs&lt;/i&gt;&amp;nbsp;de execução.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;8,1,0&quot;&gt;&lt;b data-path-to-node=&quot;8,1,0&quot; data-index-in-node=&quot;0&quot;&gt;O que ele gera:&lt;/b&gt;&amp;nbsp;O&amp;nbsp;&lt;b data-path-to-node=&quot;8,1,0&quot; data-index-in-node=&quot;18&quot;&gt;Grafo de Implementação (&lt;i data-path-to-node=&quot;8,1,0&quot; data-index-in-node=&quot;42&quot;&gt;As-Is&lt;/i&gt;)&lt;/b&gt;. Ele diz: &quot;A tabela&amp;nbsp;&lt;code data-path-to-node=&quot;8,1,0&quot; data-index-in-node=&quot;69&quot;&gt;Fornecedores&lt;/code&gt;&amp;nbsp;está fisicamente unida à tabela&amp;nbsp;&lt;code data-path-to-node=&quot;8,1,0&quot; data-index-in-node=&quot;114&quot;&gt;Contas_a_Pagar&lt;/code&gt;, e a mesma classe calcula o&amp;nbsp;&lt;i data-path-to-node=&quot;8,1,0&quot; data-index-in-node=&quot;157&quot;&gt;resilience score&lt;/i&gt;&amp;nbsp;e processa a fatura&quot;.&lt;/p&gt;&lt;/li&gt;" vertex="1">
          <mxGeometry height="192.75" width="340" x="80" y="777.25" as="geometry" />
        </mxCell>
        <mxCell id="-ppM35XShmB3G3ZkOoFj-5" parent="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fontSize=13;" value="Tatical Design&lt;div&gt;Specialist&lt;/div&gt;" vertex="1">
          <mxGeometry height="120" width="120" x="660" y="460" as="geometry" />
        </mxCell>
        <mxCell id="-ppM35XShmB3G3ZkOoFj-7" parent="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fontSize=13;" value="Strategy Design&lt;div&gt;Specialist&lt;/div&gt;" vertex="1">
